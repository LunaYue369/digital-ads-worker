                }
              }
            }
          }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "status": {"type": "string", "enum": ["success", "error"]},
          "stdout": {"type": "string"},
          "stderr": {"type": "string"},
          "cmd": {"type": "string"}
        }
      }
    },
    {
      "name": "make_ad_video",
      "description": "Build final ad video from run_dir/storyboard.json (+ optional subtitles and voiceover).",
      "exec": "/usr/bin/python3 /Users/clawbot-runner/adworker/openclaw_tools/make_ad_video_tool.py",
      "input_schema": {
